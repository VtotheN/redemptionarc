# Copy to .env only after creating NEW RedemptionArc wallets.
# Do not use Kimi/DOCTORKIMI/UNDERWHEEL wallets here.

SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
DRY_RUN=true
ALLOW_LIVE=false

# Required for snapshots/gates.
REDEMPTION_TREASURY=
REDEMPTION_CRANK=
REDEMPTION_WITHDRAW_AUTHORITY=

# Optional tracked mints.
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
HOP_MINT=HZF5k7h39hkysoSZ4ZfmWc55PhvW7ntVvVqdXFCyYGh3

# Cash gate.
MIN_NET_USD=0.25
SOL_PRICE_USD=
FORCE_ENV_SOL_PRICE=false
LEDGER_MODE=treasury

# Kimi-style cycle params.
ROUTE_VOLUME_USDC=39
HOPS=2
TX2_CUSHION_EXTRA_USDC_MICRO=4000000
TX2_MIN_CUSHION_SOL_LAMPORTS=10000000
TX2_CU_LIMIT=400000
TX2_CU_PRICE_MICRO_LAMPORTS=1000
JUPITER_SLIPPAGE_BPS=100
KEEPER_PAUSED=true
KEEPER_INTERVAL_MS=1500

# Read-only Kimi evidence import. Do not use Kimi wallets for execution.
KIMI_RECEIPTS_DIR=/Users/velon/Desktop/DOCTORKIMI-ENGINE/receipts

# Scale model targets.
TARGET_NET_USD_PER_CYCLE=1000
TARGET_NET_USD_PER_DAY=1000000
MAX_CYCLES_PER_DAY=20000
OBSERVED_ROUTE_VOLUME_USDC=39
TARGET_CYCLES_PER_DAY=1000
AGGRESSIVE_TARGETS_USD=10,25,50,100
AGGRESSIVE_CYCLES_PER_DAY=1000
